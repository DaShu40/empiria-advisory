---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Terms of Use — EMPIRIA Advisory">
<header id="header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="EMPIRIA Advisory home">
      <span class="logo-mark">E</span>
      <span class="logo-text">EMPIRIA <em>Advisory</em></span>
    </a>
    <a href="/" class="back-link">← Back to Home</a>
  </div>
</header>
<main class="legal-page">
  <div class="container">
    <h1>Terms of Use</h1>
    <p class="meta">Last updated: June 2025</p>
    <div class="legal-body">
      <h2>1. Acceptance</h2>
      <p>By accessing this website, you accept these Terms of Use. If you do not accept them, please do not use this site.</p>
      <h2>2. Content</h2>
      <p>All content on this website is for informational purposes only and does not constitute legal or regulatory advice. No attorney-client or advisory relationship is established by accessing this site.</p>
      <h2>3. Intellectual Property</h2>
      <p>All content, text, design, and materials on this website are the intellectual property of EMPIRIA Advisory and may not be reproduced without written permission.</p>
      <h2>4. Limitation of Liability</h2>
      <p>EMPIRIA Advisory shall not be liable for any damages arising from use of or reliance on information contained on this website.</p>
      <h2>5. Governing Law</h2>
      <p>These terms are governed by applicable law. Disputes shall be subject to the jurisdiction of the courts of the relevant operating jurisdiction.</p>
      <h2>6. Contact</h2>
      <p>advisor@empiriadvisory.com</p>
    </div>
  </div>
</main>
</Layout>
<style>
:root {
  --slate-900: #0B0F19;
  --accent: #4A7FCC;
  --off-white: #F0EDE6;
  --muted: #7A8EA8;
  --border: rgba(74, 127, 204, 0.15);
}
.container { max-width: 760px; margin: 0 auto; padding: 0 2rem; }
#header { padding: 1.25rem 0; border-bottom: 1px solid var(--border); }
.header-inner { max-width: 1200px; margin: 0 auto; padding: 0 2rem; display: flex; align-items: center; justify-content: space-between; }
.logo { display: flex; align-items: center; gap: 0.625rem; text-decoration: none; }
.logo-mark { width: 28px; height: 28px; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center; font-family: serif; font-size: 1rem; font-weight: 700; border-radius: 2px; }
.logo-text { font-size: 0.9375rem; font-weight: 600; color: var(--off-white); letter-spacing: 0.05em; text-transform: uppercase; }
.logo-text em { font-style: normal; font-weight: 300; color: var(--muted); }
.back-link { font-size: 0.875rem; color: var(--muted); text-decoration: none; }
.back-link:hover { color: var(--off-white); }
.legal-page { padding: 5rem 0; }
h1 { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 500; color: var(--off-white); margin-bottom: 0.5rem; }
.meta { font-family: monospace; font-size: 0.8125rem; color: var(--muted); margin-bottom: 3rem; }
.legal-body h2 { font-family: 'Playfair Display', serif; font-size: 1.125rem; font-weight: 500; color: var(--off-white); margin-top: 2rem; margin-bottom: 0.75rem; }
.legal-body p { font-size: 0.9375rem; color: var(--muted); line-height: 1.75; }
</style>
