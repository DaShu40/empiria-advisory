</Layout>

<style>
/* ═══════════════════════════════════════════════════════
   DESIGN TOKENS
═══════════════════════════════════════════════════════ */
:root {
  --slate-900: #0B0F19;
  --slate-800: #111827;
  --slate-700: #1E2A3A;
  --ink-blue: #1B3A6B;
  --ink-blue-light: #2A5298;
  --accent: #4A7FCC;
  --accent-warm: #C8A96E;
  --off-white: #F0EDE6;
  --muted: #7A8EA8;
  --border: rgba(74, 127, 204, 0.15);
  --border-strong: rgba(74, 127, 204, 0.3);
}

/* ═══════════════════════════════════════════════════════
   UTILITIES
═══════════════════════════════════════════════════════ */
.container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
}

.section-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1rem;
}

.btn-primary {
  display: inline-block;
  background: var(--accent);
  color: white;
  padding: 0.75rem 1.75rem;
  font-size: 0.875rem;
  font-weight: 500;
  letter-spacing: 0.02em;
  text-decoration: none;
  border-radius: 2px;
  transition: background 0.2s, transform 0.1s;
}
.btn-primary:hover { background: #3a6ab5; transform: translateY(-1px); }
.btn-primary.btn-sm { padding: 0.5rem 1.25rem; font-size: 0.8125rem; }
.btn-primary.btn-lg { padding: 1rem 2.5rem; font-size: 1rem; }

.btn-ghost {
  display: inline-block;
  color: var(--off-white);
  padding: 0.75rem 1.5rem;
  font-size: 0.875rem;
  font-weight: 400;
  letter-spacing: 0.02em;
  text-decoration: none;
  border: 1px solid var(--border-strong);
  border-radius: 2px;
  transition: border-color 0.2s, color 0.2s;
}
.btn-ghost:hover { border-color: var(--accent); color: var(--accent); }

/* ═══════════════════════════════════════════════════════
   HEADER
═══════════════════════════════════════════════════════ */
#header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(11, 15, 25, 0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}

.header-inner {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 2rem;
  height: 64px;
  display: flex;
  align-items: center;
  gap: 2rem;
}

.logo {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  text-decoration: none;
  flex-shrink: 0;
}
.logo-mark {
  width: 28px;
  height: 28px;
  background: var(--accent);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: 'Playfair Display', serif;
  font-size: 1rem;
  font-weight: 700;
  border-radius: 2px;
}
.logo-text {
  font-family: 'Inter', sans-serif;
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--off-white);
  letter-spacing: 0.05em;
  text-transform: uppercase;
}
.logo-text em {
  font-style: normal;
  font-weight: 300;
  color: var(--muted);
}

#header nav {
  flex: 1;
  display: flex;
  justify-content: center;
}
#header nav ul {
  display: flex;
  gap: 2rem;
  list-style: none;
  padding: 0;
  margin: 0;
}
#header nav a {
  font-size: 0.8125rem;
  color: var(--muted);
  text-decoration: none;
  letter-spacing: 0.03em;
  transition: color 0.2s;
}
#header nav a:hover { color: var(--off-white); }

.mobile-menu-btn {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  margin-left: auto;
}
.mobile-menu-btn span {
  display: block;
  width: 22px;
  height: 1.5px;
  background: var(--off-white);
  transition: transform 0.2s;
}

.mobile-nav {
  display: none;
  padding: 1.5rem 2rem;
  border-top: 1px solid var(--border);
  background: rgba(11, 15, 25, 0.98);
}
.mobile-nav.open { display: block; }
.mobile-nav ul { list-style: none; padding: 0; margin: 0; }
.mobile-nav li { padding: 0.625rem 0; border-bottom: 1px solid var(--border); }
.mobile-nav a { color: var(--off-white); text-decoration: none; font-size: 0.9375rem; }

/* ═══════════════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════════════ */
#hero {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 8rem 2rem 6rem;
  position: relative;
  overflow: hidden;
}

.hero-bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(74, 127, 204, 0.04) 1px, transparent 1px),
    linear-gradient(90deg, rgba(74, 127, 204, 0.04) 1px, transparent 1px);
  background-size: 60px 60px;
  pointer-events: none;
}

/* Signature element: The orbital diagram */
.hero-orbit {
  position: absolute;
  right: -80px;
  top: 50%;
  transform: translateY(-50%);
  width: 500px;
  height: 500px;
  pointer-events: none;
  opacity: 0.35;
}
.orbit-ring {
  position: absolute;
  top: 50%;
  left: 50%;
  border-radius: 50%;
  border: 1px solid var(--accent);
  transform: translate(-50%, -50%);
}
.orbit-ring-1 { width: 200px; height: 200px; opacity: 0.6; animation: orbit-pulse 4s ease-in-out infinite; }
.orbit-ring-2 { width: 320px; height: 320px; opacity: 0.35; animation: orbit-pulse 4s ease-in-out infinite 1.3s; }
.orbit-ring-3 { width: 440px; height: 440px; opacity: 0.2; animation: orbit-pulse 4s ease-in-out infinite 2.6s; }

@keyframes orbit-pulse {
  0%, 100% { opacity: inherit; transform: translate(-50%, -50%) scale(1); }
  50% { opacity: 0.15; transform: translate(-50%, -50%) scale(1.03); }
}

.orbit-node {
  position: absolute;
  top: 50%;
  left: 50%;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6875rem;
  letter-spacing: 0.1em;
  color: var(--accent);
  background: var(--slate-900);
  padding: 2px 6px;
  border: 1px solid var(--border-strong);
  border-radius: 2px;
  transform: translate(-50%, -50%)
    rotate(var(--angle))
    translateX(var(--r))
    rotate(calc(-1 * var(--angle)));
}

.hero-content {
  max-width: 1200px;
  margin: 0 auto;
  width: 100%;
  position: relative;
  z-index: 1;
}

.hero-content .eyebrow {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1.5rem;
}

.hero-content h1 {
  font-size: clamp(2.75rem, 6vw, 5.5rem);
  line-height: 1.05;
  font-weight: 500;
  color: var(--off-white);
  margin-bottom: 1.75rem;
  max-width: 680px;
}
.hero-content h1 em {
  font-style: italic;
  color: var(--accent);
}

.hero-sub {
  font-size: 1.125rem;
  color: var(--muted);
  line-height: 1.7;
  max-width: 520px;
  margin-bottom: 2.5rem;
}

.hero-actions {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  align-items: center;
  margin-bottom: 3rem;
}

.hero-signal {
  display: flex;
  gap: 1rem;
  align-items: center;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6875rem;
  letter-spacing: 0.12em;
  color: var(--muted);
  text-transform: uppercase;
}
.hero-signal .dot { color: var(--border-strong); }

.hero-geo {
  position: absolute;
  bottom: 3rem;
  right: 2rem;
  display: flex;
  gap: 0.75rem;
  max-width: 1200px;
}
.geo-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6875rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  text-decoration: none;
  padding: 4px 10px;
  border: 1px solid var(--border);
  border-radius: 2px;
  transition: color 0.2s, border-color 0.2s;
}
.geo-tag:hover { color: var(--accent); border-color: var(--accent); }

/* ═══════════════════════════════════════════════════════
   ZONES
═══════════════════════════════════════════════════════ */
.section-zones {
  padding: 6rem 0;
  border-top: 1px solid var(--border);
}

.section-zones h2 {
  font-size: clamp(2rem, 3.5vw, 3rem);
  font-weight: 500;
  margin-bottom: 3rem;
  line-height: 1.2;
}

.zones-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
}

.zone-card {
  background: var(--slate-900);
  padding: 2.5rem;
  transition: background 0.3s;
}
.zone-card:hover { background: var(--slate-800); }

.zone-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.25rem;
}
.zone-code {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  color: white;
  background: var(--accent);
  padding: 2px 8px;
  border-radius: 2px;
}
.zone-eu .zone-code { background: #1B5E9B; }
.zone-cn .zone-code { background: #8B1A1A; }
.zone-sg .zone-code { background: #1B6B3A; }
.zone-name {
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--off-white);
  letter-spacing: 0.03em;
}
.zone-status {
  margin-left: auto;
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.625rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #4ade80;
  display: flex;
  align-items: center;
  gap: 4px;
}
.zone-status::before {
  content: '';
  display: block;
  width: 5px;
  height: 5px;
  background: #4ade80;
  border-radius: 50%;
  animation: blink 2s ease-in-out infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.zone-card p {
  font-size: 0.9375rem;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 1.5rem;
}

.zone-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  list-style: none;
  padding: 0;
  margin: 0;
}
.zone-tags li {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.625rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--muted);
  border: 1px solid var(--border);
  padding: 2px 8px;
  border-radius: 2px;
}

/* ═══════════════════════════════════════════════════════
   PROPOSITION
═══════════════════════════════════════════════════════ */
.section-proposition {
  padding: 6rem 0;
  background: var(--slate-800);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.proposition-inner {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 5rem;
  align-items: start;
}

.proposition-left h2 {
  font-size: clamp(1.75rem, 3vw, 2.5rem);
  font-weight: 500;
  line-height: 1.2;
}
.proposition-left h2 em { font-style: italic; color: var(--accent); }

.lead-text {
  font-size: 1.0625rem;
  line-height: 1.75;
  color: var(--muted);
  margin-bottom: 2.5rem;
}

.outcome-row {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}
.outcome-item {
  display: flex;
  gap: 1rem;
  align-items: flex-start;
}
.outcome-icon {
  color: var(--accent);
  font-size: 1.25rem;
  flex-shrink: 0;
  margin-top: 2px;
}
.outcome-item strong {
  display: block;
  font-size: 0.9375rem;
  color: var(--off-white);
  margin-bottom: 0.25rem;
}
.outcome-item p {
  font-size: 0.875rem;
  color: var(--muted);
  margin: 0;
}

/* ═══════════════════════════════════════════════════════
   SERVICES
═══════════════════════════════════════════════════════ */
.section-services {
  padding: 6rem 0;
}

.section-header {
  margin-bottom: 3.5rem;
}
.section-header h2 {
  font-size: clamp(1.75rem, 3vw, 2.75rem);
  font-weight: 500;
  line-height: 1.2;
}
.section-intro {
  font-size: 1.0625rem;
  color: var(--muted);
  margin-top: 1rem;
  max-width: 560px;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
}

.service-card {
  background: var(--slate-900);
  padding: 2.5rem;
  transition: background 0.3s;
  position: relative;
}
.service-card:hover { background: var(--slate-800); }
.service-card:hover .service-num { color: var(--accent); }

.service-num {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6875rem;
  letter-spacing: 0.15em;
  color: var(--border-strong);
  margin-bottom: 1rem;
  transition: color 0.3s;
}

.service-card h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.1875rem;
  font-weight: 500;
  color: var(--off-white);
  margin-bottom: 0.875rem;
  line-height: 1.3;
}

.service-card p {
  font-size: 0.875rem;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 1.5rem;
}

.deliverable-list {
  list-style: none;
  padding: 0;
  margin: 0;
  border-top: 1px solid var(--border);
  padding-top: 1.25rem;
}
.deliverable-list li {
  font-size: 0.8125rem;
  color: var(--muted);
  padding: 0.3rem 0;
  padding-left: 1rem;
  position: relative;
}
.deliverable-list li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--accent);
  font-size: 0.75rem;
}

/* ═══════════════════════════════════════════════════════
   PROCESS
═══════════════════════════════════════════════════════ */
.section-process {
  padding: 6rem 0;
  background: var(--slate-800);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.process-inner {
  display: grid;
  grid-template-columns: 1fr 1.5fr;
  gap: 5rem;
  align-items: start;
}

.process-left h2 {
  font-size: clamp(1.75rem, 2.5vw, 2.5rem);
  font-weight: 500;
  line-height: 1.2;
  margin-bottom: 1.25rem;
}
.process-left h2 em { font-style: italic; color: var(--accent); }
.process-desc { font-size: 0.9375rem; color: var(--muted); line-height: 1.7; }

.process-steps {
  display: flex;
  flex-direction: column;
  margin-bottom: 2rem;
}

.process-step {
  display: flex;
  gap: 1.5rem;
}

.step-line {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}
.step-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
  margin-top: 4px;
}
.step-connector {
  flex: 1;
  width: 1px;
  background: var(--border-strong);
  margin: 6px 0;
  min-height: 2rem;
}

.step-content {
  padding-bottom: 2rem;
}
.step-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.625rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  display: block;
  margin-bottom: 0.375rem;
}
.step-content h4 {
  font-family: 'Playfair Display', serif;
  font-size: 1.0625rem;
  font-weight: 500;
  color: var(--off-white);
  margin-bottom: 0.5rem;
}
.step-content p {
  font-size: 0.875rem;
  color: var(--muted);
  line-height: 1.65;
  margin: 0;
}

.deliverables-box {
  border: 1px solid var(--border);
  padding: 1.5rem;
  background: rgba(74, 127, 204, 0.04);
}
.deliverables-label {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.625rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1rem;
}
.deliverables-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.deliverables-grid span {
  font-size: 0.8125rem;
  color: var(--muted);
  padding: 4px 10px;
  border: 1px solid var(--border);
  border-radius: 2px;
}

/* ═══════════════════════════════════════════════════════
   COMPARATIVE
═══════════════════════════════════════════════════════ */
.section-comparative {
  padding: 6rem 0;
}

.compare-table {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
}

.compare-col {
  background: var(--slate-900);
  transition: background 0.3s;
}
.compare-col:hover { background: var(--slate-800); }

.compare-header {
  padding: 1.25rem 2rem;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.compare-geo {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--off-white);
}
.compare-tag {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.5625rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent);
  border: 1px solid var(--border-strong);
  padding: 2px 7px;
  border-radius: 2px;
}
.compare-eu .compare-tag { color: #6BA3D6; border-color: rgba(107, 163, 214, 0.3); }
.compare-cn .compare-tag { color: #D47C7C; border-color: rgba(212, 124, 124, 0.3); }
.compare-sg .compare-tag { color: #6BC89A; border-color: rgba(107, 200, 154, 0.3); }

.compare-body {
  padding: 2rem;
}
.compare-body h3 {
  font-family: 'Playfair Display', serif;
  font-size: 1.0625rem;
  font-weight: 500;
  line-height: 1.3;
  margin-bottom: 1rem;
  color: var(--off-white);
}
.compare-body p {
  font-size: 0.875rem;
  color: var(--muted);
  line-height: 1.7;
  margin-bottom: 1.5rem;
}
.compare-body ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.compare-body li {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  color: var(--muted);
  padding: 0.4rem 0;
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.compare-body li::before {
  content: '';
  display: block;
  width: 4px;
  height: 4px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
}

/* ═══════════════════════════════════════════════════════
   RESEARCH
═══════════════════════════════════════════════════════ */
.section-research {
  padding: 6rem 0;
  background: var(--slate-800);
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.research-inner {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 5rem;
  align-items: start;
}

.research-left h2 {
  font-size: clamp(1.75rem, 2.5vw, 2.5rem);
  font-weight: 500;
  line-height: 1.2;
  margin-bottom: 1.25rem;
}
.research-left h2 em { font-style: italic; color: var(--accent); }
.research-left p { font-size: 0.9375rem; color: var(--muted); line-height: 1.7; }

.output-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1px;
  background: var(--border);
  border: 1px solid var(--border);
}

.output-item {
  background: var(--slate-900);
  padding: 1.75rem;
  transition: background 0.3s;
}
.output-item:hover { background: rgba(74, 127, 204, 0.06); }

.output-icon {
  font-size: 1.375rem;
  margin-bottom: 0.875rem;
  display: block;
}
.output-item h4 {
  font-family: 'Playfair Display', serif;
  font-size: 1rem;
  font-weight: 500;
  color: var(--off-white);
  margin-bottom: 0.625rem;
}
.output-item p {
  font-size: 0.8125rem;
  color: var(--muted);
  line-height: 1.65;
  margin: 0;
}

/* ═══════════════════════════════════════════════════════
   TRUST
═══════════════════════════════════════════════════════ */
.section-trust {
  padding: 3rem 0;
  border-top: 1px solid var(--border);
  border-bottom: 1px solid var(--border);
}

.trust-inner {
  display: flex;
  gap: 2rem;
  align-items: center;
}
.trust-icon { flex-shrink: 0; }
.trust-content { flex: 1; }
.trust-content h3 {
  font-family: 'Inter', sans-serif;
  font-size: 0.9375rem;
  font-weight: 600;
  color: var(--off-white);
  margin-bottom: 0.5rem;
}
.trust-content p {
  font-size: 0.875rem;
  color: var(--muted);
  line-height: 1.65;
  margin: 0;
}
.trust-link {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.75rem;
  color: var(--accent);
  text-decoration: none;
  white-space: nowrap;
  letter-spacing: 0.04em;
}
.trust-link:hover { text-decoration: underline; }

/* ═══════════════════════════════════════════════════════
   CTA
═══════════════════════════════════════════════════════ */
.section-cta {
  padding: 8rem 0;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.section-cta::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(74, 127, 204, 0.08) 0%, transparent 70%);
  pointer-events: none;
}

.cta-inner {
  position: relative;
  z-index: 1;
}
.cta-inner h2 {
  font-size: clamp(2rem, 4vw, 3.5rem);
  font-weight: 500;
  line-height: 1.15;
  margin-bottom: 1.25rem;
}
.cta-inner h2 em { font-style: italic; color: var(--accent); }
.cta-sub {
  font-size: 1.0625rem;
  color: var(--muted);
  max-width: 540px;
  margin: 0 auto 2.5rem;
  line-height: 1.7;
}
.cta-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}
.cta-email {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.8125rem;
  color: var(--muted);
  text-decoration: none;
  letter-spacing: 0.04em;
  transition: color 0.2s;
}
.cta-email:hover { color: var(--accent); }

/* ═══════════════════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════════════════ */
footer {
  background: var(--slate-800);
  border-top: 1px solid var(--border);
  padding: 4rem 0 2rem;
}

.footer-inner {
  display: flex;
  gap: 4rem;
  margin-bottom: 3rem;
}

.footer-brand {
  flex: 0 0 260px;
}
.footer-tagline {
  font-size: 0.8125rem;
  color: var(--muted);
  margin-top: 1rem;
  line-height: 1.6;
}
.footer-geo {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6875rem;
  letter-spacing: 0.1em;
  color: var(--muted);
  margin-top: 0.5rem;
  text-transform: uppercase;
}

.footer-links {
  flex: 1;
  display: flex;
  gap: 3rem;
}

.footer-col h5 {
  font-family: 'JetBrains Mono', monospace;
  font-size: 0.6875rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--off-white);
  margin-bottom: 1rem;
}
.footer-col ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.footer-col a {
  font-size: 0.875rem;
  color: var(--muted);
  text-decoration: none;
