---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- ═══════════════════════════════════════════════════════
     HEADER
═══════════════════════════════════════════════════════ -->
<header id="header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="EMPIRIA Advisory home">
      <span class="logo-mark">E</span>
      <span class="logo-text">EMPIRIA <em>Advisory</em></span>
    </a>
    <nav aria-label="Main navigation">
      <ul>
        <li><a href="/about">About</a></li>
        <li><a href="/services">Services</a></li>
        <li><a href="#governance">Governance</a></li>
        <li><a href="#research">Research</a></li>
        <li><a href="#contact">Contact</a></li>
      </ul>
    </nav>
    <a href="#contact" class="btn-primary btn-sm">Schedule a Consultation</a>
    <button class="mobile-menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
      <span></span><span></span><span></span>
    </button>
  </div>
  <div id="mobile-nav" class="mobile-nav" aria-hidden="true">
    <ul>
      <li><a href="/about">About</a></li>
      <li><a href="/services">Services</a></li>
      <li><a href="#governance">Governance</a></li>
      <li><a href="#research">Research</a></li>
      <li><a href="#contact">Contact</a></li>
    </ul>
    <a href="#contact" class="btn-primary" style="margin-top:1.5rem;display:inline-block;">Schedule a Consultation</a>
  </div>
</header>

<!-- ═══════════════════════════════════════════════════════
     HERO
═══════════════════════════════════════════════════════ -->
<section id="hero">
  <div class="hero-bg-grid" aria-hidden="true"></div>
  <div class="hero-orbit" aria-hidden="true">
    <div class="orbit-ring orbit-ring-1"></div>
    <div class="orbit-ring orbit-ring-2"></div>
    <div class="orbit-ring orbit-ring-3"></div>
    <div class="orbit-node" style="--angle:0deg;--r:180px">EU</div>
    <div class="orbit-node" style="--angle:120deg;--r:180px">CN</div>
    <div class="orbit-node" style="--angle:240deg;--r:180px">SG</div>
  </div>
  <div class="hero-content">
    <p class="eyebrow">Digital Governance · Compliance Intelligence</p>
    <h1>
      Turning Regulatory<br/>
      <em>Complexity</em> into<br/>
      Operational Certainty.
    </h1>
    <p class="hero-sub">
      End-to-end compliance process support across the EU, China, and Singapore — from regulatory mapping to outcome validation.
    </p>
    <div class="hero-actions">
      <a href="#contact" class="btn-primary">Schedule a Consultation</a>
      <a href="#services" class="btn-ghost">Explore Practice Areas →</a>
    </div>
    <div class="hero-signal">
      <span>Research-Driven</span>
      <span class="dot" aria-hidden="true">·</span>
      <span>Policy-Focused</span>
      <span class="dot" aria-hidden="true">·</span>
      <span>Globally Informed</span>
    </div>
  </div>
  <div class="hero-geo">
    <a href="#singapore" class="geo-tag">Singapore</a>
    <a href="#dublin" class="geo-tag">Dublin</a>
    <a href="#beijing" class="geo-tag">Beijing</a>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     REGULATORY ZONES
═══════════════════════════════════════════════════════ -->
<section id="about" class="section-zones">
  <div class="container">
    <p class="section-label">Strategic Coverage</p>
    <h2>The World's Leading<br/>Regulatory Jurisdictions</h2>
    <div class="zones-grid">
      <div id="singapore" class="zone-card zone-sg">
        <div class="zone-header">
          <span class="zone-code">SG</span>
          <span class="zone-name">Singapore</span>
          <div class="zone-status">Active</div>
        </div>
        <p>PDPA alignment, AI governance frameworks, ASEAN regulatory coordination, and innovation-compatible compliance architecture for the Asia-Pacific gateway.</p>
        <ul class="zone-tags">
          <li>PDPA</li>
          <li>AI Governance</li>
          <li>ASEAN</li>
          <li>Digital Economy</li>
        </ul>
      </div>
      <div id="dublin" class="zone-card zone-eu">
        <div class="zone-header">
          <span class="zone-code">EU</span>
          <span class="zone-name">Dublin / EU</span>
          <div class="zone-status">Active</div>
        </div>
        <p>GDPR enforcement intelligence, EU AI Act implementation support, DPC compliance architecture, and cross-border data transfer strategy from Europe's leading regulatory hub.</p>
        <ul class="zone-tags">
          <li>GDPR</li>
          <li>EU AI Act</li>
          <li>DPC</li>
          <li>DSA/DMA</li>
        </ul>
      </div>
      <div id="beijing" class="zone-card zone-cn">
        <div class="zone-header">
          <span class="zone-code">CN</span>
          <span class="zone-name">Beijing</span>
          <div class="zone-status">Active</div>
        </div>
        <p>China AI governance execution, PIPL and DSL compliance process design, CAC framework navigation, and end-to-end compliance implementation for the world's most complex digital regulatory environment.</p>
        <ul class="zone-tags">
          <li>PIPL</li>
          <li>DSL</li>
          <li>CAC</li>
          <li>AI Governance</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     VALUE PROPOSITION
═══════════════════════════════════════════════════════ -->
<section class="section-proposition">
  <div class="container">
    <div class="proposition-inner">
      <div class="proposition-left">
        <p class="section-label">Our Approach</p>
        <h2>From Regulatory Fragmentation<br/>to <em>Structured Clarity</em></h2>
      </div>
      <div class="proposition-right">
        <p class="lead-text">
          Regulatory systems across the EU, China, and Asia-Pacific overlap, conflict, and evolve at different velocities. EMPIRIA translates this complexity into structured compliance processes, delivering operational outcomes — not advisory documents.
        </p>
        <div class="outcome-row">
          <div class="outcome-item">
            <span class="outcome-icon">◈</span>
            <div>
              <strong>Risk Mitigation</strong>
              <p>Identify exposure before regulators do</p>
            </div>
          </div>
          <div class="outcome-item">
            <span class="outcome-icon">◈</span>
            <div>
              <strong>Regulatory Alignment</strong>
              <p>Cross-jurisdiction compliance by design</p>
            </div>
          </div>
          <div class="outcome-item">
            <span class="outcome-icon">◈</span>
            <div>
              <strong>Operational Certainty</strong>
              <p>Compliance as a business enabler</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     PRACTICE AREAS
═══════════════════════════════════════════════════════ -->
<section id="services" class="section-services">
  <div class="container">
    <div class="section-header">
      <p class="section-label">Practice Areas</p>
      <h2>Deliverable-Oriented<br/>Advisory Across Six Domains</h2>
    </div>
    <div class="services-grid">
      <article class="service-card">
        <div class="service-num">01</div>
        <h3>Artificial Intelligence Governance</h3>
        <p>Compliance frameworks, AI risk classification under EU AI Act and emerging Asian regimes, governance model design, and algorithmic accountability architecture.</p>
        <ul class="deliverable-list">
          <li>AI risk classification reports</li>
          <li>Governance model documentation</li>
          <li>Regulatory gap analysis</li>
        </ul>
      </article>
      <article class="service-card">
        <div class="service-num">02</div>
        <h3>Data Governance & Privacy</h3>
        <p>GDPR and PIPL alignment strategies, cross-border data transfer solutions, privacy-by-design integration, and DPA enforcement intelligence.</p>
        <ul class="deliverable-list">
          <li>Privacy notice architecture</li>
          <li>Transfer mechanism analysis</li>
          <li>DPA engagement strategy</li>
        </ul>
      </article>
      <article class="service-card">
        <div class="service-num">03</div>
        <h3>Comparative Digital Governance</h3>
        <p>Multi-jurisdiction regulatory mapping, EU–China–ASEAN alignment strategy, and comparative policy analysis for organizations operating across regulatory boundaries.</p>
        <ul class="deliverable-list">
          <li>Regulatory mapping reports</li>
          <li>Cross-jurisdiction strategy</li>
          <li>Policy comparison briefs</li>
        </ul>
      </article>
      <article class="service-card">
        <div class="service-num">04</div>
        <h3>Digital Infrastructure Policy</h3>
        <p>Cloud and CDN compliance under data sovereignty frameworks, infrastructure risk assessment, and localization requirement analysis across target markets.</p>
        <ul class="deliverable-list">
          <li>Infrastructure compliance audit</li>
          <li>Sovereignty risk assessment</li>
          <li>Cloud localization roadmap</li>
        </ul>
      </article>
      <article class="service-card">
        <div class="service-num">05</div>
        <h3>China Compliance Execution</h3>
        <p>End-to-end implementation support for PIPL, DSL, CAC, and MLPS frameworks — from regulatory mapping through process design to final operational validation.</p>
        <ul class="deliverable-list">
          <li>PIPL compliance process design</li>
          <li>CAC filing support</li>
          <li>Operational readiness validation</li>
        </ul>
      </article>
      <article class="service-card">
        <div class="service-num">06</div>
        <h3>Economic Security & Tech Policy</h3>
        <p>Supply chain regulatory risk, geopolitical impact analysis on technology operations, and forward-looking regulatory forecasting for strategic planning.</p>
        <ul class="deliverable-list">
          <li>Supply chain risk reports</li>
          <li>Geopolitical scenario analysis</li>
          <li>Regulatory forecast briefs</li>
        </ul>
      </article>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     CHINA EXECUTION PROCESS
═══════════════════════════════════════════════════════ -->
<section class="section-process">
  <div class="container">
    <div class="process-inner">
      <div class="process-left">
        <p class="section-label">China Compliance</p>
        <h2>End-to-End Execution<br/>in the World's Most Complex<br/><em>Digital Regulatory Environment</em></h2>
        <p class="process-desc">China's regulatory stack — PIPL, DSL, CAC, MLPS 2.0, and the emerging AI governance regime — requires structured implementation, not just advisory analysis. EMPIRIA delivers the full execution process.</p>
        <a href="#contact" class="btn-primary" style="margin-top:2rem;display:inline-block;">Discuss China Compliance</a>
      </div>
      <div class="process-right">
        <div class="process-steps">
          <div class="process-step">
            <div class="step-line">
              <div class="step-dot"></div>
              <div class="step-connector"></div>
            </div>
            <div class="step-content">
              <span class="step-label">Phase 01</span>
              <h4>Regulatory Mapping</h4>
              <p>Identify all applicable obligations across PIPL, DSL, CAC, and sector-specific regulations for your operational context.</p>
            </div>
          </div>
          <div class="process-step">
            <div class="step-line">
              <div class="step-dot"></div>
              <div class="step-connector"></div>
            </div>
            <div class="step-content">
              <span class="step-label">Phase 02</span>
              <h4>Compliance Design</h4>
              <p>Build structured compliance processes aligned to regulatory requirements, with clear accountability and documentation architecture.</p>
            </div>
          </div>
          <div class="process-step">
            <div class="step-line">
              <div class="step-dot"></div>
              <div class="step-connector"></div>
            </div>
            <div class="step-content">
              <span class="step-label">Phase 03</span>
              <h4>Implementation Support</h4>
              <p>Hands-on execution assistance: policy drafting, technical controls guidance, regulatory filing, and stakeholder coordination.</p>
            </div>
          </div>
          <div class="process-step">
            <div class="step-line">
              <div class="step-dot"></div>
            </div>
            <div class="step-content">
              <span class="step-label">Phase 04</span>
              <h4>Outcome Validation</h4>
              <p>Final review against regulatory requirements, operational readiness confirmation, and ongoing monitoring setup.</p>
            </div>
          </div>
        </div>
        <div class="deliverables-box">
          <p class="deliverables-label">Final Deliverables</p>
          <div class="deliverables-grid">
            <span>Compliance frameworks</span>
            <span>Risk assessment reports</span>
            <span>Implementation roadmaps</span>
            <span>Regulatory alignment mapping</span>
            <span>Operational readiness validation</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     COMPARATIVE GOVERNANCE
═══════════════════════════════════════════════════════ -->
<section id="governance" class="section-comparative">
  <div class="container">
    <div class="section-header">
      <p class="section-label">Comparative Governance</p>
      <h2>Cross-Border Regulatory Clarity<br/>for Strategic Decision-Making</h2>
      <p class="section-intro">
        Three regulatory systems. Three governance philosophies. One coherent operational strategy.
      </p>
    </div>
    <div class="compare-table">
      <div class="compare-col compare-eu">
        <div class="compare-header">
          <span class="compare-geo">EU / Ireland</span>
          <div class="compare-tag">Rights-Based</div>
        </div>
        <div class="compare-body">
          <h3>Risk-Based Governance + Enforcement Precedent</h3>
          <p>GDPR enforcement under DPC jurisdiction, risk-tiered AI Act obligations, DSA/DMA platform accountability, and a growing body of enforcement precedent that shapes global compliance norms.</p>
          <ul>
            <li>GDPR / EU AI Act</li>
            <li>DSA / DMA</li>
            <li>DPC enforcement intelligence</li>
            <li>Data transfer frameworks</li>
          </ul>
        </div>
      </div>
      <div class="compare-col compare-cn">
        <div class="compare-header">
          <span class="compare-geo">China</span>
          <div class="compare-tag">State-Directed</div>
        </div>
        <div class="compare-body">
          <h3>State-Directed Execution + Compliance Process Design</h3>
          <p>A dense, rapidly evolving regulatory stack combining PIPL's privacy obligations, DSL's data security hierarchy, CAC's content and algorithm rules, and the world's first enacted AI-specific statute.</p>
          <ul>
            <li>PIPL / DSL</li>
            <li>CAC AI Regulations</li>
            <li>MLPS 2.0</li>
            <li>Cross-border transfer rules</li>
          </ul>
        </div>
      </div>
      <div class="compare-col compare-sg">
        <div class="compare-header">
          <span class="compare-geo">Singapore</span>
          <div class="compare-tag">Adaptive</div>
        </div>
        <div class="compare-body">
          <h3>Adaptive Governance + Innovation Architecture</h3>
          <p>Singapore's pragmatic framework — PDPA modernisation, voluntary AI governance model frameworks, and a strategic intent to be the governance bridge between Western and Asian regulatory systems.</p>
          <ul>
            <li>PDPA / NRIC</li>
            <li>AI Governance Framework</li>
            <li>MAS regulatory sandbox</li>
            <li>ASEAN coordination</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     RESEARCH / INTELLIGENCE
═══════════════════════════════════════════════════════ -->
<section id="research" class="section-research">
  <div class="container">
    <div class="research-inner">
      <div class="research-left">
        <p class="section-label">Research & Intelligence</p>
        <h2>Regulatory Intelligence<br/>Grounded in<br/><em>Academic Rigour</em></h2>
        <p>EMPIRIA's advisory work draws on doctoral-level comparative governance research, longitudinal regulatory analysis, and primary-source monitoring of DPA enforcement, legislative developments, and policy signals across all three jurisdictions.</p>
        <p style="margin-top:1rem">This research foundation separates us from compliance checklists: every strategic recommendation is built on documented regulatory evidence.</p>
      </div>
      <div class="research-right">
        <div class="output-grid">
          <div class="output-item">
            <div class="output-icon">📄</div>
            <h4>Regulatory Briefs</h4>
            <p>Concise analysis of new legislative developments and enforcement precedents across target jurisdictions.</p>
          </div>
          <div class="output-item">
            <div class="output-icon">📊</div>
            <h4>Executive Summaries</h4>
            <p>Board-ready synthesis of regulatory risk exposure and strategic compliance options.</p>
          </div>
          <div class="output-item">
            <div class="output-icon">🗺</div>
            <h4>Policy Mapping Reports</h4>
            <p>Structured mapping of obligations across overlapping regulatory frameworks for multi-jurisdiction operations.</p>
          </div>
          <div class="output-item">
            <div class="output-icon">⚖</div>
            <h4>Cross-Jurisdiction Analysis</h4>
            <p>Comparative analysis identifying alignment opportunities and conflict zones across EU, Chinese, and ASEAN regulatory systems.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     PRIVACY / TRUST SIGNAL
═══════════════════════════════════════════════════════ -->
<section class="section-trust">
  <div class="container">
    <div class="trust-inner">
      <div class="trust-icon" aria-hidden="true">
        <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M20 4L6 10V20C6 27.8 12.2 35.1 20 37C27.8 35.1 34 27.8 34 20V10L20 4Z" stroke="#4A7FCC" stroke-width="1.5" fill="none"/>
          <path d="M14 20L18 24L26 16" stroke="#4A7FCC" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </div>
      <div class="trust-content">
        <h3>Privacy by Design. Minimal Data Collection. Maximum Transparency.</h3>
        <p>EMPIRIA uses only strictly necessary technologies required for website security and functionality. No advertising trackers, no behavioural profiling, no third-party analytics. This site is built to the same privacy-by-design standard we recommend to clients.</p>
      </div>
      <a href="/privacy" class="trust-link">View Privacy Policy →</a>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     CTA
═══════════════════════════════════════════════════════ -->
<section id="contact" class="section-cta">
  <div class="container">
    <div class="cta-inner">
      <p class="section-label" style="color:var(--accent)">Get in Touch</p>
      <h2>Transform Regulatory Complexity<br/>into <em>Operational Certainty</em></h2>
      <p class="cta-sub">Work with EMPIRIA Advisory across Singapore, Dublin, and Beijing to design and implement compliance strategies that deliver measurable outcomes.</p>
      <div class="cta-actions">
        <a href="mailto:advisor@empiriadvisory.com" class="btn-primary btn-lg">Engage EMPIRIA Advisory</a>
        <a href="mailto:advisor@empiriadvisory.com" class="cta-email">advisor@empiriadvisory.com</a>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════════════════════════════════════
     FOOTER
═══════════════════════════════════════════════════════ -->
<footer>
  <div class="container">
    <div class="footer-inner">
      <div class="footer-brand">
        <a href="/" class="logo" aria-label="EMPIRIA Advisory home">
          <span class="logo-mark">E</span>
          <span class="logo-text">EMPIRIA <em>Advisory</em></span>
        </a>
