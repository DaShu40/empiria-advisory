---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    id: 'ai-governance',
    num: '01',
    title: 'Artificial Intelligence Governance',
    tagline: 'From risk classification to governance architecture',
    description: 'AI systems face concurrent regulation across the EU AI Act, China\'s CAC algorithmic and generative AI regulations, and Singapore\'s voluntary AI governance frameworks. EMPIRIA designs compliance frameworks that address overlapping obligations without duplicating effort.',
    scope: [
      'AI system risk classification under EU AI Act (prohibited, high-risk, limited, minimal)',
      'Governance model design: accountability structures, documentation requirements, human oversight',
      'CAC algorithm transparency and security assessment support',
      'Generative AI compliance under China\'s 2023 Interim Measures',
      'Board-level AI governance policy drafting',
      'AI risk register design and implementation',
    ],
    deliverables: ['AI Risk Classification Report', 'AI Governance Framework Document', 'Regulatory Gap Analysis', 'Policy and Procedure Suite'],
    jurisdictions: ['EU / Ireland', 'China', 'Singapore'],
  },
  {
    id: 'data-privacy',
    num: '02',
    title: 'Data Governance & Privacy',
    tagline: 'GDPR, PIPL, and cross-border data strategy',
    description: 'Data governance obligations under GDPR and China\'s PIPL create a complex dual-track compliance environment for organisations with EU and Chinese operations. Our approach begins with comparative obligation mapping and produces production-ready documentation architecture.',
    scope: [
      'GDPR compliance architecture: legal basis analysis, ROPA, privacy notices, DPIA programmes',
      'PIPL compliance: consent mechanisms, cross-border transfer standard contracts, important data management',
      'Cross-border data transfer solutions: SCCs, BCRs, Chinese CAC-approved mechanisms',
      'DPA engagement strategy and enforcement risk assessment',
      'Privacy-by-design integration into product and technical processes',
      'Data subject rights fulfilment process design',
    ],
    deliverables: ['Privacy Notice Architecture', 'Cross-Border Transfer Analysis', 'ROPA Documentation', 'DPIA Template and Process', 'DPA Engagement Strategy'],
    jurisdictions: ['EU / Ireland', 'China', 'Singapore'],
  },
  {
    id: 'comparative-governance',
    num: '03',
    title: 'Comparative Digital Governance',
    tagline: 'Multi-jurisdiction clarity for strategic decisions',
    description: 'For organisations navigating regulatory obligations across two or more jurisdictions, a siloed approach to compliance creates duplication, contradiction, and strategic blindness. Comparative governance analysis identifies where obligations align, where they conflict, and where strategic design choices can resolve both simultaneously.',
    scope: [
      'Regulatory obligation mapping across EU, China, and ASEAN jurisdictions',
      'Conflict identification: where GDPR and PIPL obligations directly contradict',
      'Strategic alignment opportunities: compliance approaches that satisfy multiple frameworks',
      'EU–China regulatory trajectory analysis for multi-year planning',
      'ASEAN emerging regulation monitoring and impact assessment',
      'Geopolitical regulatory risk analysis for technology operations',
    ],
    deliverables: ['Multi-Jurisdiction Regulatory Map', 'Conflict and Alignment Analysis', 'Strategic Compliance Roadmap', 'Executive Policy Brief'],
    jurisdictions: ['EU / Ireland', 'China', 'Singapore', 'ASEAN'],
  },
  {
    id: 'digital-infrastructure',
    num: '04',
    title: 'Digital Infrastructure Policy',
    tagline: 'Cloud, CDN, and data sovereignty compliance',
    description: 'Data sovereignty requirements in China (DSL, MLPS), EU data localisation trends, and sector-specific infrastructure requirements create significant operational constraints for cloud-dependent organisations. We assess compliance obligations and design infrastructure strategies that satisfy regulatory requirements without unnecessary operational burden.',
    scope: [
      'Data localisation obligation analysis under DSL and MLPS 2.0',
      'Cloud architecture review against Chinese regulatory requirements',
      'CDN compliance assessment for content delivery in China',
      'EU data residency requirements under sector-specific regulation',
      'Critical information infrastructure (CII) designation risk assessment',
      'Infrastructure compliance roadmap and vendor guidance',
    ],
    deliverables: ['Infrastructure Compliance Audit', 'Data Sovereignty Risk Assessment', 'Cloud Localisation Roadmap', 'Vendor Compliance Guidance'],
    jurisdictions: ['China', 'EU'],
  },
  {
    id: 'china-execution',
    num: '05',
    title: 'China Compliance Execution',
    tagline: 'End-to-end implementation in a complex environment',
    description: 'Advisory on China\'s regulatory requirements is widely available. What organisations actually need is structured implementation support that turns regulatory obligations into operational realities — filing the right documents, building the right processes, and validating the outcome. EMPIRIA delivers the full execution cycle.',
    scope: [
      'PIPL compliance programme design and implementation',
      'DSL compliance assessment and security management programme',
      'CAC filing support: algorithm filing, security assessment coordination',
      'MLPS 2.0 security classification and compliance implementation',
      'Generative AI service filing and compliance programme',
      'Ongoing regulatory monitoring and compliance maintenance',
    ],
    deliverables: ['Full Compliance Process Documentation', 'Filing Support', 'Staff Training Materials', 'Operational Readiness Validation Report'],
    jurisdictions: ['China'],
  },
  {
    id: 'economic-security',
    num: '06',
    title: 'Economic Security & Tech Policy',
    tagline: 'Regulatory forecasting for strategic planning',
    description: 'Digital regulation is increasingly shaped by geopolitical competition. Export controls, technology standard-setting battles, investment screening, and supply chain security requirements all create regulatory exposure for technology companies. EMPIRIA maps these risks and provides forward-looking analysis for strategic planning.',
    scope: [
      'Supply chain regulatory risk assessment (US BIS, EU, China SAMR)',
      'Technology export control compliance framework',
      'Geopolitical scenario analysis for technology operations',
      'Standard-setting strategy: ISO, ITU, IEEE, ETSI regulatory dynamics',
      'Digital infrastructure foreign investment screening analysis',
      'Regulatory forecasting: 12–36 month trajectory analysis',
    ],
    deliverables: ['Supply Chain Risk Report', 'Geopolitical Scenario Analysis', 'Regulatory Forecast Brief', 'Strategic Options Paper'],
    jurisdictions: ['EU', 'China', 'US'],
  },
];
---

<Layout
  title="Services — EMPIRIA Advisory"
  description="EMPIRIA Advisory's six practice areas: AI Governance, Data Privacy, Comparative Digital Governance, Digital Infrastructure Policy, China Compliance Execution, and Economic Security & Tech Policy."
>

<header id="header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="EMPIRIA Advisory home">
      <span class="logo-mark">E</span>
      <span class="logo-text">EMPIRIA <em>Advisory</em></span>
    </a>
    <nav>
      <ul>
        <li><a href="/about">About</a></li>
        <li><a href="/#governance">Governance</a></li>
        <li><a href="/#research">Research</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
    </nav>
    <a href="/#contact" class="btn-primary btn-sm">Schedule a Consultation</a>
  </div>
</header>

<main>
  <!-- PAGE HERO — dark section -->
  <section class="page-hero">
    <div class="container">
      <p class="section-label">Practice Areas</p>
      <h1>Deliverable-Oriented Advisory<br/>Across <em>Six Domains</em></h1>
      <p class="hero-sub">Every engagement produces documented, actionable outputs — not advisory decks. Below is the scope and deliverable set for each practice area.</p>
    </div>
  </section>

  <!-- SERVICE INDEX -->
  <div class="services-layout">
    <aside class="services-nav" aria-label="Service navigation">
      <ul>
        {services.map(s => (
          <li>
            <a href={`#${s.id}`}>
              <span class="nav-num">{s.num}</span>
              <span>{s.title}</span>
            </a>
          </li>
        ))}
      </ul>
    </aside>
    <div class="services-content">
      {services.map(s => (
        <article id={s.id} class="service-detail">
          <div class="sd-header">
            <span class="sd-num">{s.num}</span>
            <div>
              <h2>{s.title}</h2>
              <p class="sd-tagline">{s.tagline}</p>
            </div>
            <div class="sd-jurisdictions">
              {s.jurisdictions.map(j => <span class="jur-tag">{j}</span>)}
            </div>
          </div>
          <p class="sd-description">{s.description}</p>
          <div class="sd-body">
            <div class="sd-scope">
              <p class="block-label">Scope</p>
              <ul>
                {s.scope.map(item => <li>{item}</li>)}
              </ul>
            </div>
            <div class="sd-deliverables">
              <p class="block-label">Deliverables</p>
              <ul class="deliverable-chips">
                {s.deliverables.map(d => <li>{d}</li>)}
              </ul>
              <a href="/#contact" class="engage-link">Engage on this area →</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>

  <!-- CTA — black section -->
  <section class="svc-cta">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container">
      <h2>Not Sure Where to Start?</h2>
      <p>Many organisations begin with a regulatory mapping exercise to understand their exposure across jurisdictions. Get in touch to discuss a scoping conversation.</p>
      <a href="mailto:advisor@empiriadvisory.com" class="btn-primary">advisor@empiriadvisory.com</a>
    </div>
  </section>
</main>

<footer>
  <div class="container footer-inner">
    <p>© 2025 EMPIRIA Advisory</p>
    <div class="footer-links">
      <a href="/">Home</a>
      <a href="/about">About</a>
      <a href="/privacy">Privacy</a>
    </div>
  </div>
</footer>

</Layout>

<style>
.container { max-width: var(--content-width); margin: 0 auto; padding: 0 2rem; }
.section-label { font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; display: block; }

/* HEADER */
#header { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.72); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid transparent; transition: border-color 0.3s; }
.header-inner { max-width: 1200px; margin: 0 auto; padding: 0 2rem; height: 44px; display: flex; align-items: center; gap: 2rem; }
.logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
.logo-mark { width: 24px; height: 24px; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 700; border-radius: 4px; }
.logo-text { font-size: 0.875rem; font-weight: 600; color: var(--text-primary-light); letter-spacing: 0.04em; text-transform: uppercase; }
.logo-text em { font-style: normal; font-weight: 300; color: var(--text-secondary-light); }
nav { flex: 1; display: flex; justify-content: center; }
nav ul { display: flex; gap: 2rem; list-style: none; padding: 0; margin: 0; }
nav a { font-size: 0.8125rem; color: var(--text-primary-light); text-decoration: none; opacity: 0.8; transition: opacity 0.2s; }
nav a:hover { opacity: 1; }
.btn-primary { display: inline-block; background: var(--accent); color: white; padding: 12px 22px; font-size: 17px; text-decoration: none; border-radius: 980px; transition: background 0.2s; line-height: 1; }
.btn-primary:hover { background: var(--accent-hover); }
.btn-primary.btn-sm { padding: 8px 16px; font-size: 15px; }

/* PAGE HERO — dark */
.page-hero { background: var(--bg-black); padding: 120px 0 80px; text-align: center; }
.page-hero .section-label { color: var(--text-secondary-dark); }
h1 { font-size: clamp(2.5rem, 7vw, 72px); font-weight: 600; line-height: 1.05; color: var(--text-primary-dark); margin-bottom: 1.5rem; letter-spacing: -0.02em; }
h1 em { font-style: italic; color: var(--accent); }
.hero-sub { font-size: 19px; color: var(--text-secondary-dark); line-height: 1.6; max-width: 600px; margin: 0 auto; }

/* LAYOUT */
.services-layout { display: grid; grid-template-columns: 220px 1fr; max-width: var(--content-width); margin: 0 auto; padding: 0 2rem; gap: 4rem; background: var(--bg-white); }

/* SIDEBAR */
.services-nav { padding-top: 3rem; }
.services-nav ul { list-style: none; padding: 0; margin: 0; position: sticky; top: 60px; }
.services-nav li { border-bottom: 1px solid var(--border-light); }
.services-nav a { display: flex; gap: 0.75rem; align-items: baseline; padding: 0.875rem 0; text-decoration: none; color: var(--text-secondary-light); font-size: 0.8125rem; line-height: 1.4; transition: color 0.2s; }
.services-nav a:hover { color: var(--text-primary-light); }
.nav-num { font-family: monospace; font-size: 11px; color: var(--accent); letter-spacing: 0.1em; flex-shrink: 0; }

/* SERVICE DETAIL */
.services-content { padding: 3rem 0 5rem; background: var(--bg-white); }
.service-detail { padding: 4rem 0; border-bottom: 1px solid var(--border-light); }
.service-detail:first-child { padding-top: 3rem; }
.service-detail:last-child { border-bottom: none; }

.sd-header { display: flex; gap: 1.5rem; align-items: flex-start; margin-bottom: 1.5rem; flex-wrap: wrap; }
.sd-num { font-family: monospace; font-size: 11px; color: var(--accent); letter-spacing: 0.15em; padding-top: 6px; flex-shrink: 0; }
h2 { font-size: clamp(1.25rem, 3vw, 28px); font-weight: 600; color: var(--text-primary-light); margin-bottom: 0.25rem; letter-spacing: -0.01em; }
.sd-tagline { font-size: 15px; color: var(--accent); }

.sd-jurisdictions { margin-left: auto; display: flex; gap: 0.5rem; flex-wrap: wrap; }
.jur-tag { font-size: 11px; color: var(--text-secondary-light); border: 1px solid var(--border-light); padding: 3px 10px; border-radius: 980px; white-space: nowrap; }

.sd-description { font-size: 17px; color: var(--text-secondary-light); line-height: 1.75; margin-bottom: 2rem; max-width: 640px; }

.sd-body { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; }
.block-label { font-family: monospace; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; display: block; }

.sd-scope ul { list-style: none; padding: 0; margin: 0; }
.sd-scope li { font-size: 15px; color: var(--text-secondary-light); padding: 0.4rem 0 0.4rem 1rem; border-bottom: 1px solid var(--border-light); position: relative; line-height: 1.5; }
.sd-scope li::before { content: '→'; position: absolute; left: 0; color: var(--accent); font-size: 0.75rem; }

.deliverable-chips { list-style: none; padding: 0; margin: 0 0 1.5rem; display: flex; flex-direction: column; gap: 0.5rem; }
.deliverable-chips li { font-size: 15px; color: var(--text-primary-light); padding: 8px 16px; background: #F5F5F7; border: 1px solid var(--border-light); border-radius: 980px; }

.engage-link { font-size: 15px; color: var(--accent); text-decoration: none; display: inline-block; margin-top: 0.5rem; transition: transform 0.2s; }
.engage-link:hover { transform: translateX(4px); }

/* CTA — black section */
.svc-cta { background: var(--bg-black); padding: 140px 0; text-align: center; position: relative; overflow: hidden; }
.cta-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 400px; height: 400px; background: radial-gradient(circle, rgba(0,102,204,0.15) 0%, transparent 70%); pointer-events: none; border-radius: 50%; }
.svc-cta h2 { font-size: clamp(2rem, 5vw, 56px); font-weight: 600; color: var(--text-primary-dark); margin-bottom: 1rem; letter-spacing: -0.02em; position: relative; z-index: 1; }
.svc-cta p { font-size: 19px; color: var(--text-secondary-dark); max-width: 480px; margin: 0 auto 2rem; line-height: 1.6; position: relative; z-index: 1; }
.svc-cta .btn-primary { position: relative; z-index: 1; }

footer { background: #F5F5F7; border-top: 1px solid var(--border-light); padding: 2rem 0; }
.footer-inner { display: flex; justify-content: space-between; align-items: center; }
footer p { font-size: 13px; color: var(--text-secondary-light); margin: 0; }
.footer-links { display: flex; gap: 1.5rem; }
.footer-links a { font-size: 13px; color: var(--text-secondary-light); text-decoration: none; transition: color 0.2s; }
.footer-links a:hover { color: var(--text-primary-light); }

@media (max-width: 900px) {
  .services-layout { grid-template-columns: 1fr; gap: 0; }
  .services-nav { display: none; }
  .sd-body { grid-template-columns: 1fr; }
  .sd-jurisdictions { margin-left: 0; }
  nav { display: none; }
}
@media (max-width: 768px) {
  h1 { font-size: clamp(2rem, 10vw, 42px); }
  .hero-sub { font-size: 17px; }
  h2 { font-size: clamp(1.25rem, 7vw, 24px); }
  .page-hero { padding: 7rem 0 4rem; }
  .svc-cta { padding: 7rem 0; }
}
</style>

<script>
const init = () => {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const els = document.querySelectorAll('h1, h2, .service-detail, .hero-sub, .section-label');
  const easing = 'cubic-bezier(0.25, 0.46, 0.45, 0.94)';
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
      obs.unobserve(el);
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
  els.forEach((el, i) => {
    const h = el as HTMLElement;
    h.style.opacity = '0';
    h.style.transform = 'translateY(30px)';
    h.style.transition = `opacity 0.7s ${easing} ${(i % 4) * 100}ms, transform 0.7s ${easing} ${(i % 4) * 100}ms`;
    obs.observe(el);
  });
  const header = document.querySelector('#header') as HTMLElement;
  if (!header) return;
  window.addEventListener('scroll', () => {
    header.style.borderBottomColor = window.scrollY > 60 ? 'rgba(0,0,0,0.1)' : 'transparent';
  }, { passive: true });
};
if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
</script>
