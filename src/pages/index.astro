</Layout>

<style>
/* ═══════════════════════════════════════════════════════
   UTILITIES
═══════════════════════════════════════════════════════ */
.container {
  max-width: var(--content-width);
  margin: 0 auto;
  padding: 0 2rem;
}

.section-label {
  font-family: var(--font-body);
  font-size: 0.75rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1rem;
  display: block;
}

/* BUTTONS */
.btn-primary {
  display: inline-block;
  background: var(--accent);
  color: white;
  padding: 12px 22px;
  font-size: 17px;
  font-weight: 400;
  text-decoration: none;
  border-radius: 980px;
  transition: background 0.2s;
  line-height: 1;
}
.btn-primary:hover { background: var(--accent-hover); }
.btn-primary.btn-sm { padding: 8px 16px; font-size: 15px; }
.btn-primary.btn-lg { padding: 16px 32px; font-size: 19px; }

.btn-secondary {
  display: inline-block;
  color: var(--accent);
  padding: 12px 4px;
  font-size: 17px;
  font-weight: 400;
  text-decoration: none;
  border-radius: 980px;
  transition: transform 0.2s;
}
.btn-secondary:hover { transform: translateX(4px); }

/* ═══════════════════════════════════════════════════════
   HEADER — frosted glass
═══════════════════════════════════════════════════════ */
#header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: rgba(255, 255, 255, 0.72);
  backdrop-filter: blur(20px) saturate(180%);
  -webkit-backdrop-filter: blur(20px) saturate(180%);
  border-bottom: 1px solid transparent;
  transition: border-bottom-color 0.3s;
}

.header-inner {
  max-width: var(--content-wide);
  margin: 0 auto;
  padding: 0 2rem;
  height: 44px;
  display: flex;
  align-items: center;
  gap: 2rem;
}

.logo {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  text-decoration: none;
  flex-shrink: 0;
}
.logo-mark {
  width: 24px;
  height: 24px;
  background: var(--accent);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
  font-weight: 700;
  border-radius: 4px;
}
.logo-text {
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--text-primary-light);
  letter-spacing: 0.04em;
  text-transform: uppercase;
}
.logo-text em {
  font-style: normal;
  font-weight: 300;
  color: var(--text-secondary-light);
}

#header nav {
  flex: 1;
  display: flex;
  justify-content: center;
}
#header nav ul {
  display: flex;
  gap: 2rem;
  list-style: none;
  padding: 0;
  margin: 0;
}
#header nav a {
  font-size: 0.8125rem;
  color: var(--text-primary-light);
  text-decoration: none;
  transition: color 0.2s;
  opacity: 0.8;
}
#header nav a:hover { opacity: 1; }

.mobile-menu-btn {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 4px;
  margin-left: auto;
}
.mobile-menu-btn span {
  display: block;
  width: 20px;
  height: 1.5px;
  background: var(--text-primary-light);
  transition: transform 0.2s;
}

.mobile-nav {
  display: none;
  padding: 1rem 2rem 1.5rem;
  border-top: 1px solid var(--border-light);
  background: rgba(255,255,255,0.98);
}
.mobile-nav.open { display: block; }
.mobile-nav ul { list-style: none; padding: 0; margin: 0; }
.mobile-nav li { padding: 0.625rem 0; border-bottom: 1px solid var(--border-light); }
.mobile-nav a { color: var(--text-primary-light); text-decoration: none; font-size: 0.9375rem; }

/* ═══════════════════════════════════════════════════════
   HERO — full viewport, black bg
═══════════════════════════════════════════════════════ */
#hero {
  min-height: 100svh;
  background: var(--bg-black);
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 8rem 2rem 6rem;
  position: relative;
}

.hero-content {
  max-width: 700px;
  margin: 0 auto;
  position: relative;
  z-index: 1;
}

.hero-content .eyebrow {
  color: var(--text-secondary-dark);
  margin-bottom: 2rem;
}

.hero-content h1 {
  font-size: clamp(2.5rem, 7vw, 80px);
  line-height: 1.05;
  font-weight: 600;
  color: var(--text-primary-dark);
  margin-bottom: 1.5rem;
  letter-spacing: -0.02em;
}
.hero-content h1 em {
  font-style: italic;
  color: var(--accent);
}

.hero-sub {
  font-size: 21px;
  color: var(--text-secondary-dark);
  line-height: 1.6;
  max-width: 600px;
  margin: 0 auto 2.5rem;
}

.hero-actions {
  display: flex;
  gap: 16px;
  flex-wrap: wrap;
  align-items: center;
  justify-content: center;
  margin-bottom: 3rem;
}

.hero-signal {
  display: flex;
  gap: 0.75rem;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  font-family: monospace;
  color: var(--text-secondary-light);
  letter-spacing: 0.04em;
}
.hero-signal .dot { color: #444; }

.hero-scroll-indicator {
  position: absolute;
  bottom: 2.5rem;
  left: 50%;
  transform: translateX(-50%);
  animation: bounce 2s ease-in-out infinite;
}
@keyframes bounce {
  0%, 100% { transform: translateX(-50%) translateY(0); }
  50% { transform: translateX(-50%) translateY(6px); }
}

/* ═══════════════════════════════════════════════════════
   REGULATORY ZONES — white section
═══════════════════════════════════════════════════════ */
.section-zones {
  background: var(--bg-white);
  padding: 100px 0;
  text-align: center;
}

.section-zones h2 {
  font-size: clamp(2rem, 4vw, 56px);
  font-weight: 600;
  color: var(--text-primary-light);
  line-height: 1.1;
  margin-bottom: 3.5rem;
  max-width: 700px;
  margin-left: auto;
  margin-right: auto;
  letter-spacing: -0.02em;
}

.zones-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.zone-card {
  background: var(--bg-card-light);
  border-radius: 18px;
  box-shadow: 2px 4px 16px rgba(0,0,0,0.08);
  padding: 40px;
  text-align: left;
  transition: transform 0.3s cubic-bezier(0.25,0.46,0.45,0.94), box-shadow 0.3s;
}
.zone-card:hover {
  transform: translateY(-4px);
  box-shadow: 4px 8px 28px rgba(0,0,0,0.14);
}

.zone-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 1rem;
}

.zone-code {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  color: white;
  padding: 3px 10px;
  border-radius: 980px;
}
.zone-code-eu { background: var(--accent); }
.zone-code-cn { background: #FF3B30; }
.zone-code-sg { background: #34C759; }

.zone-status {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  color: #34C759;
  font-weight: 500;
}
.status-dot {
  width: 6px;
  height: 6px;
  background: #34C759;
  border-radius: 50%;
  animation: blink 2s ease-in-out infinite;
}
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.zone-card h3 {
  font-size: 24px;
  font-weight: 600;
  color: var(--text-primary-light);
  margin-bottom: 12px;
  letter-spacing: -0.01em;
}

.zone-card p {
  font-size: 17px;
  color: var(--text-secondary-light);
  line-height: 1.6;
  margin-bottom: 1.5rem;
}

.zone-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  list-style: none;
  padding: 0;
  margin: 0;
}
.zone-tags li {
  font-size: 12px;
  color: var(--text-secondary-light);
  background: #F5F5F7;
  padding: 4px 12px;
  border-radius: 980px;
}

/* ═══════════════════════════════════════════════════════
   VALUE PROPOSITION — black section
═══════════════════════════════════════════════════════ */
.section-proposition {
  background: var(--bg-black);
  padding: 100px 0;
  text-align: center;
}

.section-proposition h2 {
  font-size: clamp(2.5rem, 6vw, 72px);
  font-weight: 600;
  color: var(--text-primary-dark);
  line-height: 1.08;
  margin-bottom: 1.5rem;
  letter-spacing: -0.02em;
  max-width: 800px;
  margin-left: auto;
  margin-right: auto;
}

.proposition-body {
  font-size: 19px;
  color: var(--text-secondary-dark);
  line-height: 1.6;
  max-width: 680px;
  margin: 0 auto 4rem;
}

.outcome-strip {
  display: flex;
  align-items: stretch;
  justify-content: center;
  gap: 0;
  max-width: 860px;
  margin: 0 auto;
  border-top: 1px solid var(--border-dark);
  border-bottom: 1px solid var(--border-dark);
}

.outcome-divider {
  width: 1px;
  background: var(--border-dark);
  flex-shrink: 0;
}

.outcome-item {
  flex: 1;
  padding: 2.5rem 2rem;
  text-align: center;
}
.outcome-icon {
  display: flex;
  justify-content: center;
  margin-bottom: 1rem;
}
.outcome-item strong {
  display: block;
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary-dark);
  margin-bottom: 0.5rem;
}
.outcome-item p {
  font-size: 14px;
  color: var(--text-secondary-dark);
  margin: 0;
  line-height: 1.5;
}

/* ═══════════════════════════════════════════════════════
   PRACTICE AREAS — white section
═══════════════════════════════════════════════════════ */
.section-services {
  background: var(--bg-white);
  padding: 100px 0;
  text-align: center;
}

.section-header {
  margin-bottom: 3.5rem;
}
.section-header h2 {
  font-size: clamp(2rem, 4vw, 56px);
  font-weight: 600;
  color: var(--text-primary-light);
  line-height: 1.1;
  letter-spacing: -0.02em;
}
.section-intro {
  font-size: 19px;
  color: var(--text-secondary-light);
  margin-top: 1rem;
  max-width: 560px;
  margin-left: auto;
  margin-right: auto;
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: var(--border-light);
  border: 1px solid var(--border-light);
}

.service-card {
  background: var(--bg-card-light);
  padding: 40px;
  text-align: left;
  transition: background 0.3s;
  position: relative;
}
.service-card:hover { background: #F5F5F7; }
.service-card:hover .card-cta { opacity: 1; }

.service-num {
  font-size: 12px;
  font-family: monospace;
  color: var(--accent);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin-bottom: 1rem;
}

.service-card h3 {
  font-size: 24px;
  font-weight: 600;
  color: var(--text-primary-light);
  margin-bottom: 0.875rem;
  line-height: 1.2;
  letter-spacing: -0.01em;
}

.service-card p {
  font-size: 15px;
  color: var(--text-secondary-light);
  line-height: 1.6;
  margin-bottom: 1.5rem;
}

.deliverable-list {
  list-style: none;
  padding: 0;
  margin: 0;
  border-top: 1px solid var(--border-light);
  padding-top: 1.25rem;
}
.deliverable-list li {
  font-size: 13px;
  color: var(--text-secondary-light);
  padding: 0.3rem 0;
  padding-left: 1rem;
  position: relative;
}
.deliverable-list li::before {
  content: '→';
  position: absolute;
  left: 0;
  color: var(--accent);
  font-size: 0.75rem;
}

.card-cta {
  display: block;
  margin-top: 1.25rem;
  font-size: 15px;
  color: var(--accent);
  font-weight: 500;
  opacity: 0;
  transition: opacity 0.2s;
}

/* ═══════════════════════════════════════════════════════
   CHINA PROCESS — black section
═══════════════════════════════════════════════════════ */
.section-process {
  background: var(--bg-black);
  padding: 100px 0;
}

.process-inner {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 5rem;
  align-items: start;
}

.process-left h2 {
  font-size: clamp(2rem, 4vw, 56px);
  font-weight: 600;
  color: var(--text-primary-dark);
  line-height: 1.1;
  margin-bottom: 1.25rem;
  letter-spacing: -0.02em;
}
.process-left h2 em { font-style: italic; color: var(--accent); }
.process-desc { font-size: 17px; color: var(--text-secondary-dark); line-height: 1.6; }

.process-steps {
  display: flex;
  flex-direction: column;
  margin-bottom: 2rem;
}

.process-step {
  display: flex;
  gap: 1.5rem;
}

.step-line {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
}
.step-dot {
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--accent);
  flex-shrink: 0;
  margin-top: 4px;
}
.step-connector {
  flex: 1;
  width: 1px;
  background: var(--border-dark);
  margin: 6px 0;
  min-height: 2rem;
}

.step-content {
  padding-bottom: 2rem;
}
.step-label {
  font-size: 11px;
  font-family: monospace;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  display: block;
  margin-bottom: 0.375rem;
}
.step-content h4 {
  font-size: 19px;
  font-weight: 600;
  color: var(--text-primary-dark);
  margin-bottom: 0.5rem;
}
.step-content p {
  font-size: 15px;
  color: var(--text-secondary-dark);
  line-height: 1.65;
  margin: 0;
}

.deliverables-box {
  border: 1px solid var(--border-dark);
  border-radius: 12px;
  padding: 24px;
}
.deliverables-label {
  font-size: 11px;
  font-family: monospace;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
  margin-bottom: 1rem;
}
.deliverables-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
}
.deliverables-grid span {
  font-size: 13px;
  color: var(--text-secondary-dark);
  padding: 5px 12px;
  background: var(--bg-dark);
  border-radius: 980px;
}

/* ═══════════════════════════════════════════════════════
   COMPARATIVE GOVERNANCE — white section
═══════════════════════════════════════════════════════ */
.section-comparative {
  background: var(--bg-white);
  padding: 100px 0;
  text-align: center;
}

.section-comparative .section-header h2 {
  font-size: clamp(2rem, 4vw, 56px);
  font-weight: 600;
  color: var(--text-primary-light);
  line-height: 1.1;
  letter-spacing: -0.02em;
}
.section-intro {
  font-size: 19px;
  color: var(--text-secondary-light);
  margin-top: 1rem;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
  line-height: 1.5;
}

.compare-table {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
  margin-top: 3.5rem;
}

.compare-col {
  background: var(--bg-card-light);
  border-radius: 18px;
  box-shadow: 2px 4px 16px rgba(0,0,0,0.08);
  overflow: hidden;
  text-align: left;
  position: relative;
  display: flex;
  flex-direction: column;
}

.compare-accent-bar {
  height: 4px;
  width: 100%;
}
.compare-eu .compare-accent-bar { background: var(--accent); }
.compare-cn .compare-accent-bar { background: #FF3B30; }
.compare-sg .compare-accent-bar { background: #34C759; }

.compare-header-label {
  padding: 0 36px 24px;
  font-size: 11px;
  font-family: monospace;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-secondary-light);
  margin-top: auto;
}

.compare-body {
  padding: 28px 36px 16px;
  flex: 1;
}

.compare-tag-pill {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 4px 12px;
  border-radius: 980px;
  margin-bottom: 1rem;
}
.compare-eu .compare-tag-pill { background: rgba(0,102,204,0.1); color: var(--accent); }
.compare-cn .compare-tag-pill { background: rgba(255,59,48,0.1); color: #FF3B30; }
.compare-sg .compare-tag-pill { background: rgba(52,199,89,0.1); color: #34C759; }

.compare-body h3 {
  font-size: 17px;
  font-weight: 600;
  line-height: 1.3;
  margin-bottom: 1rem;
  color: var(--text-primary-light);
}

.compare-body p {
  font-size: 14px;
  color: var(--text-secondary-light);
  line-height: 1.7;
  margin-bottom: 1.5rem;
}
.compare-body ul {
  list-style: none;
  padding: 0;
  margin: 0;
}
.compare-body li {
  font-size: 14px;
  color: var(--text-secondary-light);
  padding: 0.4rem 0;
  border-bottom: 1px solid var(--border-light);
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.compare-body li::before {
  content: '';
  display: block;
  width: 5px;
  height: 5px;
  border-radius: 50%;
  flex-shrink: 0;
}
.compare-eu .compare-body li::before { background: var(--accent); }
.compare-cn .compare-body li::before { background: #FF3B30; }
.compare-sg .compare-body li::before { background: #34C759; }

/* ═══════════════════════════════════════════════════════
   RESEARCH — black section
═══════════════════════════════════════════════════════ */
.section-research {
  background: var(--bg-black);
  padding: 100px 0;
}

.research-inner {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 5rem;
  align-items: start;
}

.research-left h2 {
  font-size: clamp(2rem, 4vw, 56px);
  font-weight: 600;
  color: var(--text-primary-dark);
  line-height: 1.1;
  margin-bottom: 1.25rem;
  letter-spacing: -0.02em;
}
.research-left h2 em { font-style: italic; color: var(--accent); }
.research-left p { font-size: 17px; color: var(--text-secondary-dark); line-height: 1.6; }

.output-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

.output-item {
  background: var(--bg-dark);
  border-radius: 12px;
  border: 1px solid var(--border-dark);
  padding: 28px;
  transition: border-color 0.3s;
}
.output-item:hover { border-color: #555; }

.output-icon {
  font-size: 32px;
  margin-bottom: 0.875rem;
  display: block;
}
.output-item h4 {
  font-size: 17px;
  font-weight: 600;
  color: var(--text-primary-dark);
  margin-bottom: 0.625rem;
}
.output-item p {
  font-size: 14px;
  color: var(--text-secondary-dark);
  line-height: 1.65;
  margin: 0;
}

/* ═══════════════════════════════════════════════════════
   TRUST STRIP — white section
═══════════════════════════════════════════════════════ */
.section-trust {
  background: var(--bg-white);
  border-top: 1px solid var(--border-light);
  border-bottom: 1px solid var(--border-light);
  padding: 0;
}

.trust-inner {
  display: flex;
  gap: 2rem;
  align-items: center;
  min-height: 80px;
  padding: 1.25rem 0;
}
.trust-icon { flex-shrink: 0; }
.trust-content { flex: 1; }
.trust-content h3 {
  font-size: 15px;
  font-weight: 600;
  color: var(--text-primary-light);
  margin-bottom: 0.25rem;
}
.trust-content p {
  font-size: 14px;
  color: var(--text-secondary-light);
  line-height: 1.5;
  margin: 0;
}
.trust-link {
  font-size: 15px;
  color: var(--accent);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
}
.trust-link:hover { text-decoration: underline; }

/* ═══════════════════════════════════════════════════════
   CTA — black section
═══════════════════════════════════════════════════════ */
.section-cta {
  background: var(--bg-black);
  padding: 200px 0;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.cta-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 400px;
  height: 400px;
  background: radial-gradient(circle, rgba(0,102,204,0.15) 0%, transparent 70%);
  pointer-events: none;
  border-radius: 50%;
}

.cta-inner {
  position: relative;
  z-index: 1;
}
.cta-inner h2 {
  font-size: clamp(2.5rem, 6vw, 72px);
  font-weight: 600;
  color: var(--text-primary-dark);
  line-height: 1.08;
  margin-bottom: 1.25rem;
  letter-spacing: -0.02em;
}
.cta-inner h2 em { font-style: italic; color: var(--accent); }
.cta-sub {
  font-size: 19px;
  color: var(--text-secondary-dark);
  max-width: 500px;
  margin: 0 auto 2.5rem;
  line-height: 1.6;
}
.cta-actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}
.cta-email {
  font-family: monospace;
  font-size: 15px;
  color: var(--text-secondary-dark);
  text-decoration: none;
  transition: color 0.2s;
}
.cta-email:hover { color: var(--accent); }

/* ═══════════════════════════════════════════════════════
   FOOTER
═══════════════════════════════════════════════════════ */
footer {
  background: #F5F5F7;
  border-top: 1px solid var(--border-light);
  padding: 4rem 0 2rem;
}

.footer-inner {
  display: flex;
  gap: 4rem;
  margin-bottom: 3rem;
}

.footer-brand { flex: 0 0 240px; }
.footer-tagline {
  font-size: 13px;
  color: var(--text-secondary-light);
  margin-top: 1rem;
  line-height: 1.6;
}
.footer-geo {
  font-family: monospace;
  font-size: 11px;
  letter-spacing: 0.08em;
  color: var(--text-secondary-light);
  margin-top: 0.5rem;
  text-transform: uppercase;
}

.footer-links {
  flex: 1;
  display: flex;
  gap: 3rem;
}

.footer-col h5 {
  font-family: monospace;
  font-size: 11px;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-primary-light);
  margin-bottom: 1rem;
}
.footer-col ul {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.footer-col a {
  font-size: 14px;
  color: var(--text-secondary-light);
  text-decoration: none;
  transition: color 0.2s;
}
.footer-col a:hover { color: var(--text-primary-light); }

.footer-bottom {
  border-top: 1px solid var(--border-light);
  padding-top: 1.5rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.footer-bottom p {
  font-size: 13px;
  color: var(--text-secondary-light);
  margin: 0;
}

/* ═══════════════════════════════════════════════════════
   RESPONSIVE
═══════════════════════════════════════════════════════ */
@media (max-width: 1024px) {
  .zones-grid,
  .services-grid,
  .compare-table {
    grid-template-columns: 1fr 1fr;
  }
  .process-inner,
  .research-inner {
    grid-template-columns: 1fr;
