---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="About — EMPIRIA Advisory"
  description="EMPIRIA Advisory is a digital governance consultancy specialising in AI, data, and digital regulation across the EU, China, and Singapore."
>

<header id="header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="EMPIRIA Advisory home">
      <span class="logo-mark">E</span>
      <span class="logo-text">EMPIRIA <em>Advisory</em></span>
    </a>
    <nav>
      <ul>
        <li><a href="/#services">Services</a></li>
        <li><a href="/#governance">Governance</a></li>
        <li><a href="/#research">Research</a></li>
        <li><a href="/#contact">Contact</a></li>
      </ul>
    </nav>
    <a href="/#contact" class="btn-primary btn-sm">Schedule a Consultation</a>
  </div>
</header>

<main>
  <!-- HERO — dark section -->
  <section class="about-hero">
    <div class="container">
      <p class="section-label">About EMPIRIA</p>
      <h1>A Different Kind of<br/><em>Governance Advisory</em></h1>
      <p class="hero-sub">
        We operate at the intersection of academic rigour and operational execution — translating doctoral-level regulatory research into compliance outcomes that work in practice.
      </p>
    </div>
  </section>

  <!-- MISSION — white section -->
  <section class="about-section section-white">
    <div class="container">
      <div class="two-col">
        <div>
          <p class="section-label">Our Mission</p>
          <h2>Governance That Actually Gets Done</h2>
        </div>
        <div class="prose">
          <p>
            Most organisations face the same paradox: the regulatory complexity they must navigate grows faster than their internal capacity to address it. Legal advisors provide opinions. Technology vendors sell platforms. Neither delivers the structured compliance process that turns a regulation into an operational reality.
          </p>
          <p>
            EMPIRIA fills that gap. We design and implement compliance processes end-to-end — from the initial regulatory mapping through to outcome validation — with measurable deliverables at every stage.
          </p>
          <p>
            Our advisory is grounded in comparative governance research spanning the EU, China, and Asia-Pacific, and in direct experience with the enforcement realities that matter most: DPC and CNIL enforcement patterns, CAC implementation practice, and the emerging AI governance regimes now reshaping digital operations globally.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- EXPERTISE PILLARS — black section -->
  <section class="about-section section-black">
    <div class="container">
      <p class="section-label" style="color:var(--text-secondary-dark)">Research Foundation</p>
      <h2 style="color:var(--text-primary-dark)">Built on Comparative Governance Research</h2>
      <div class="pillars-grid">
        <div class="pillar">
          <div class="pillar-icon">⚖</div>
          <h3>EU Digital Regulation</h3>
          <p>Deep expertise in GDPR enforcement, EU AI Act implementation, DSA/DMA compliance, and the regulatory dynamics of the Irish DPC as the lead supervisory authority for most major global technology operations in Europe.</p>
          <ul>
            <li>GDPR enforcement intelligence</li>
            <li>EU AI Act risk classification</li>
            <li>DPC engagement strategy</li>
            <li>Cross-border transfer frameworks</li>
          </ul>
        </div>
        <div class="pillar">
          <div class="pillar-icon">龙</div>
          <h3>China Regulatory Execution</h3>
          <p>Operational knowledge of China's digital regulatory stack — PIPL, DSL, CAC algorithm and AI regulations, MLPS 2.0 — combined with on-the-ground implementation experience in one of the world's most complex and rapidly evolving regulatory environments.</p>
          <ul>
            <li>PIPL compliance process design</li>
            <li>CAC AI regulation implementation</li>
            <li>Cross-border data transfer rules</li>
            <li>Sector-specific requirements</li>
          </ul>
        </div>
        <div class="pillar">
          <div class="pillar-icon">⬡</div>
          <h3>Comparative Digital Governance</h3>
          <p>Systematic comparative analysis of governance models across jurisdictions — examining how different regulatory philosophies (rights-based, state-directed, adaptive) create both obligations and strategic opportunities for organisations operating across borders.</p>
          <ul>
            <li>Multi-jurisdiction regulatory mapping</li>
            <li>Policy convergence analysis</li>
            <li>Techno-nationalism and standard-setting</li>
            <li>Economic statecraft implications</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- DIFFERENTIATORS — white section -->
  <section class="about-section section-white">
    <div class="container">
      <div class="two-col">
        <div>
          <p class="section-label">Why EMPIRIA</p>
          <h2>What Separates Research-Driven Advisory</h2>
        </div>
        <div>
          <div class="diff-list">
            <div class="diff-item">
              <span class="diff-num">01</span>
              <div>
                <h4>Enforcement Intelligence, Not Just Legal Text</h4>
                <p>Regulatory compliance is shaped as much by enforcement practice as by statute. Our analysis incorporates DPA decision patterns, enforcement database research, and CAC implementation signals — the intelligence that determines what compliance actually requires.</p>
              </div>
            </div>
            <div class="diff-item">
              <span class="diff-num">02</span>
              <div>
                <h4>Deliverables, Not Advisory Documents</h4>
                <p>Every engagement produces concrete outputs: compliance frameworks, implementation roadmaps, policy documents, risk assessments. Not a presentation with recommendations to be operationalised later.</p>
              </div>
            </div>
            <div class="diff-item">
              <span class="diff-num">03</span>
              <div>
                <h4>Cross-Jurisdiction by Design</h4>
                <p>For organisations operating across the EU, China, and Asia-Pacific, compliance cannot be siloed by jurisdiction. Our comparative governance foundation allows us to design solutions that account for regulatory interaction from the start.</p>
              </div>
            </div>
            <div class="diff-item">
              <span class="diff-num">04</span>
              <div>
                <h4>Academic Rigour in Operational Context</h4>
                <p>PhD-level comparative governance research underpins every engagement. This means our regulatory analysis is systematic, documented, and testable — not opinion dressed as expertise.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA — black section -->
  <section class="about-cta">
    <div class="cta-glow" aria-hidden="true"></div>
    <div class="container">
      <h2>Ready to Move from Regulatory Complexity<br/>to <em>Operational Certainty</em>?</h2>
      <a href="/#contact" class="btn-primary btn-lg">Schedule a Consultation</a>
      <p class="cta-email"><a href="mailto:advisor@empiriadvisory.com">advisor@empiriadvisory.com</a></p>
    </div>
  </section>
</main>

<footer>
  <div class="container footer-inner">
    <p>© 2025 EMPIRIA Advisory</p>
    <div class="footer-links">
      <a href="/">Home</a>
      <a href="/privacy">Privacy Policy</a>
      <a href="/terms">Terms of Use</a>
    </div>
  </div>
</footer>

</Layout>

<style>
.container { max-width: var(--content-width); margin: 0 auto; padding: 0 2rem; }
.section-label { font-size: 0.75rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem; display: block; }

/* HEADER */
#header { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,0.72); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); border-bottom: 1px solid transparent; transition: border-color 0.3s; }
.header-inner { max-width: 1200px; margin: 0 auto; padding: 0 2rem; height: 44px; display: flex; align-items: center; gap: 2rem; }
.logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
.logo-mark { width: 24px; height: 24px; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 700; border-radius: 4px; }
.logo-text { font-size: 0.875rem; font-weight: 600; color: var(--text-primary-light); letter-spacing: 0.04em; text-transform: uppercase; }
.logo-text em { font-style: normal; font-weight: 300; color: var(--text-secondary-light); }
nav { flex: 1; display: flex; justify-content: center; }
nav ul { display: flex; gap: 2rem; list-style: none; padding: 0; margin: 0; }
nav a { font-size: 0.8125rem; color: var(--text-primary-light); text-decoration: none; opacity: 0.8; transition: opacity 0.2s; }
nav a:hover { opacity: 1; }
.btn-primary { display: inline-block; background: var(--accent); color: white; padding: 12px 22px; font-size: 17px; text-decoration: none; border-radius: 980px; transition: background 0.2s; line-height: 1; }
.btn-primary:hover { background: var(--accent-hover); }
.btn-primary.btn-sm { padding: 8px 16px; font-size: 15px; }
.btn-primary.btn-lg { padding: 16px 32px; font-size: 19px; }

/* ABOUT HERO — dark */
.about-hero { background: var(--bg-black); padding: 120px 0 80px; text-align: center; }
.about-hero .section-label { color: var(--text-secondary-dark); }
h1 { font-size: clamp(2.5rem, 7vw, 72px); font-weight: 600; line-height: 1.05; color: var(--text-primary-dark); margin-bottom: 1.5rem; letter-spacing: -0.02em; }
h1 em { font-style: italic; color: var(--accent); }
.hero-sub { font-size: 21px; color: var(--text-secondary-dark); line-height: 1.6; max-width: 600px; margin: 0 auto; }

/* SECTIONS */
.about-section { padding: 100px 0; }
.section-white { background: var(--bg-white); }
.section-black { background: var(--bg-black); }
.two-col { display: grid; grid-template-columns: 1fr 1.4fr; gap: 5rem; align-items: start; }
h2 { font-size: clamp(1.75rem, 4vw, 48px); font-weight: 600; line-height: 1.1; color: var(--text-primary-light); letter-spacing: -0.02em; }
.prose p { font-size: 17px; color: var(--text-secondary-light); line-height: 1.75; margin-bottom: 1.25rem; }

/* PILLARS */
.pillars-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-top: 3rem; }
.pillar { background: var(--bg-dark); border: 1px solid var(--border-dark); border-radius: 18px; padding: 36px; transition: border-color 0.3s; }
.pillar:hover { border-color: #555; }
.pillar-icon { font-size: 1.5rem; margin-bottom: 1rem; display: block; }
.pillar h3 { font-size: 20px; font-weight: 600; color: var(--text-primary-dark); margin-bottom: 0.875rem; }
.pillar p { font-size: 15px; color: var(--text-secondary-dark); line-height: 1.7; margin-bottom: 1.25rem; }
.pillar ul { list-style: none; padding: 0; margin: 0; border-top: 1px solid var(--border-dark); padding-top: 1rem; }
.pillar li { font-size: 13px; color: var(--text-secondary-dark); padding: 0.3rem 0 0.3rem 1rem; position: relative; }
.pillar li::before { content: '→'; position: absolute; left: 0; color: var(--accent); }

/* DIFFERENTIATORS */
.diff-list { display: flex; flex-direction: column; gap: 0; }
.diff-item { display: flex; gap: 1.5rem; padding: 2rem 0; border-bottom: 1px solid var(--border-light); }
.diff-item:last-child { border-bottom: none; padding-bottom: 0; }
.diff-num { font-family: monospace; font-size: 12px; color: var(--accent); letter-spacing: 0.1em; flex-shrink: 0; padding-top: 3px; min-width: 28px; }
.diff-item h4 { font-size: 19px; font-weight: 600; color: var(--text-primary-light); margin-bottom: 0.625rem; letter-spacing: -0.01em; }
.diff-item p { font-size: 15px; color: var(--text-secondary-light); line-height: 1.7; margin: 0; }

/* CTA */
.about-cta { background: var(--bg-black); padding: 160px 0; text-align: center; position: relative; overflow: hidden; }
.cta-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 400px; height: 400px; background: radial-gradient(circle, rgba(0,102,204,0.15) 0%, transparent 70%); pointer-events: none; border-radius: 50%; }
.about-cta h2 { font-size: clamp(2rem, 5vw, 56px); font-weight: 600; line-height: 1.1; color: var(--text-primary-dark); margin-bottom: 2rem; letter-spacing: -0.02em; position: relative; z-index: 1; }
.about-cta h2 em { font-style: italic; color: var(--accent); }
.about-cta .btn-primary { position: relative; z-index: 1; }
.cta-email { margin-top: 1.25rem; position: relative; z-index: 1; }
.cta-email a { font-family: monospace; font-size: 15px; color: var(--text-secondary-dark); text-decoration: none; transition: color 0.2s; }
.cta-email a:hover { color: var(--accent); }

/* FOOTER */
footer { background: #F5F5F7; border-top: 1px solid var(--border-light); padding: 2rem 0; }
.footer-inner { display: flex; justify-content: space-between; align-items: center; }
footer p { font-size: 13px; color: var(--text-secondary-light); margin: 0; }
.footer-links { display: flex; gap: 1.5rem; }
.footer-links a { font-size: 13px; color: var(--text-secondary-light); text-decoration: none; transition: color 0.2s; }
.footer-links a:hover { color: var(--text-primary-light); }

/* RESPONSIVE */
@media (max-width: 900px) {
  .two-col { grid-template-columns: 1fr; gap: 2.5rem; }
  .pillars-grid { grid-template-columns: 1fr; }
  nav { display: none; }
  .footer-inner { flex-direction: column; gap: 1rem; }
}
@media (max-width: 768px) {
  h1 { font-size: clamp(2rem, 10vw, 42px); }
  .hero-sub { font-size: 17px; }
  h2 { font-size: clamp(1.5rem, 8vw, 32px); }
  .about-section { padding: 5rem 0; }
  .about-hero { padding: 7rem 0 5rem; }
  .about-cta { padding: 7rem 0; }
}
</style>

<script>
const init = () => {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const els = document.querySelectorAll('h1, h2, h4, .pillar, .diff-item, .hero-sub, .prose p, .section-label');
  const easing = 'cubic-bezier(0.25, 0.46, 0.45, 0.94)';
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (!entry.isIntersecting) return;
      const el = entry.target as HTMLElement;
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
      obs.unobserve(el);
    });
  }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
  els.forEach((el, i) => {
    const h = el as HTMLElement;
    h.style.opacity = '0';
    h.style.transform = 'translateY(30px)';
    h.style.transition = `opacity 0.7s ${easing} ${(i % 4) * 100}ms, transform 0.7s ${easing} ${(i % 4) * 100}ms`;
    obs.observe(el);
  });
  const header = document.querySelector('#header') as HTMLElement;
  if (!header) return;
  window.addEventListener('scroll', () => {
    header.style.borderBottomColor = window.scrollY > 60 ? 'rgba(0,0,0,0.1)' : 'transparent';
  }, { passive: true });
};
if (document.readyState === 'loading') { document.addEventListener('DOMContentLoaded', init); } else { init(); }
</script>
