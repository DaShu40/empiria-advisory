---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Terms of Use — EMPIRIA Advisory">
<header id="header">
  <div class="header-inner">
    <a href="/" class="logo" aria-label="EMPIRIA Advisory home">
      <span class="logo-mark">E</span>
      <span class="logo-text">EMPIRIA <em>Advisory</em></span>
    </a>
    <a href="/" class="back-link">← Back to Home</a>
  </div>
</header>
<main class="legal-page">
  <div class="container">
    <h1>Terms of Use</h1>
    <p class="meta">Last updated: June 2025</p>
    <div class="legal-body">
      <h2>1. Acceptance</h2>
      <p>By accessing this website, you accept these Terms of Use. If you do not accept them, please do not use this site.</p>
      <h2>2. Content</h2>
      <p>All content on this website is for informational purposes only and does not constitute legal or regulatory advice. No attorney-client or advisory relationship is established by accessing this site.</p>
      <h2>3. Intellectual Property</h2>
      <p>All content, text, design, and materials on this website are the intellectual property of EMPIRIA Advisory and may not be reproduced without written permission.</p>
      <h2>4. Limitation of Liability</h2>
      <p>EMPIRIA Advisory shall not be liable for any damages arising from use of or reliance on information contained on this website.</p>
      <h2>5. Governing Law</h2>
      <p>These terms are governed by applicable law. Disputes shall be subject to the jurisdiction of the courts of the relevant operating jurisdiction.</p>
      <h2>6. Contact</h2>
      <p>advisor@empiriadvisory.com</p>
    </div>
  </div>
</main>
</Layout>
<style>
.container { max-width: 760px; margin: 0 auto; padding: 0 2rem; }
#header { background: rgba(255,255,255,0.72); backdrop-filter: blur(20px) saturate(180%); -webkit-backdrop-filter: blur(20px) saturate(180%); padding: 0; border-bottom: 1px solid var(--border-light); position: sticky; top: 0; z-index: 100; }
.header-inner { max-width: 1200px; margin: 0 auto; padding: 0 2rem; height: 44px; display: flex; align-items: center; justify-content: space-between; }
.logo { display: flex; align-items: center; gap: 0.5rem; text-decoration: none; }
.logo-mark { width: 24px; height: 24px; background: var(--accent); color: white; display: flex; align-items: center; justify-content: center; font-size: 0.875rem; font-weight: 700; border-radius: 4px; }
.logo-text { font-size: 0.875rem; font-weight: 600; color: var(--text-primary-light); letter-spacing: 0.04em; text-transform: uppercase; }
.logo-text em { font-style: normal; font-weight: 300; color: var(--text-secondary-light); }
.back-link { font-size: 15px; color: var(--accent); text-decoration: none; transition: opacity 0.2s; }
.back-link:hover { opacity: 0.7; }
.legal-page { background: var(--bg-white); padding: 6rem 0; min-height: 80vh; }
h1 { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 48px); font-weight: 600; color: var(--text-primary-light); margin-bottom: 0.5rem; letter-spacing: -0.02em; }
.meta { font-family: monospace; font-size: 13px; color: var(--text-secondary-light); margin-bottom: 3rem; }
.legal-body h2 { font-family: var(--font-display); font-size: 19px; font-weight: 600; color: var(--text-primary-light); margin-top: 2.5rem; margin-bottom: 0.75rem; }
.legal-body p { font-size: 17px; color: var(--text-secondary-light); line-height: 1.75; }
</style>
